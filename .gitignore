# ── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
dist-ssr/
*.egg-info/
*.egg
.eggs/
.pytest_cache/
.coverage
htmlcov/

# ── Virtual environments ─────────────────────────────────
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ── Node / Frontend ──────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.eslintcache
*.local
*-debug.log*

# ── Rust / Tauri (desktop shell) ─────────────────────────
# build artifacts; Cargo.lock IS committed (it's an application).
# the configured build also targets an external CARGO_TARGET_DIR.
target/
src-tauri/target/
src-tauri/gen/
*.pdb

# ── Local data & runtime state (recreated on startup) ────
# uploaded papers, the vector store, and the persisted model
# selection (data/active_model.txt) all live here
data/

# ── Model weights (kept outside the repo; ignore if copied in) ──
*.gguf

# ── Environment variables ────────────────────────────────
.env
.env.*
!.env.example

# ── Wheels / build artifacts ─────────────────────────────
*.whl

# ── LaTeX build outputs (keep .tex and .pdf) ─────────────
docs/*.aux
docs/*.log
docs/*.out
docs/*.toc
docs/*.synctex.gz

# ── IDE / Editor / OS ────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.sln
*~
.DS_Store

#local
local/
